# 当前配置样例用于本地开发和部署配置对照，实际敏感配置应写入 backend/.env、显式传入的配置文件或部署平台环境变量。
# 在 backend 目录启动时，可通过 `cargo run -- --config .env.example` 验证指定配置文件加载链路。

# 应用运行环境，可按部署环境设置为 local、test、staging 或 production。
APP_ENV=local

# HTTP 服务监听地址，容器内通常使用 0.0.0.0，本机限定访问可改为 127.0.0.1。
SERVER_HOST=0.0.0.0

# HTTP 服务监听端口，必须是合法的 0-65535 端口号。
SERVER_PORT=8080

# 数据库类型，当前支持 mysql、postgres、postgresql、pg，其中默认运行目标为 mysql。
DATABASE_TYPE=mysql

# 数据库连接串，MySQL 使用 mysql://，PostgreSQL 使用 postgres:// 或 postgresql://。
DATABASE_URL=mysql://root:root@127.0.0.1:3306/taipus

# 数据库连接池最大连接数，必须大于 0。
DATABASE_MAX_CONNECTIONS=20

# 数据库连接池最小连接数，不得大于 DATABASE_MAX_CONNECTIONS。
DATABASE_MIN_CONNECTIONS=1

# 获取数据库连接的超时时间，单位为秒。
DATABASE_CONNECT_TIMEOUT_SECONDS=5

# 是否在服务启动时自动执行 Refinery migration，支持 true/false/1/0/yes/no/on/off。
DATABASE_RUN_MIGRATIONS=true

# tracing 日志过滤级别，常用值为 error、warn、info、debug、trace。
RUST_LOG=info

# 多语言默认 locale，必须和 backend/locales 中的资源文件 locale 保持一致。
I18N_DEFAULT_LOCALE=zh-CN

# 多语言支持 locale 列表，逗号分隔；配置会在启动时规范化并校验资源文件是否存在。
I18N_SUPPORTED_LOCALES=zh-CN,en-US

# 默认 IANA time zone，业务代码不得写死默认展示时区。
I18N_DEFAULT_TIME_ZONE=Asia/Shanghai

# 支持的 IANA time zone 列表，逗号分隔；未配置时只启用默认时区。
I18N_SUPPORTED_TIME_ZONES=Asia/Shanghai,UTC,America/New_York

# 系统多语言资源版本，用于前端和移动端缓存失效。
I18N_SYSTEM_RESOURCE_VERSION=202604280001

# 默认租户 ID。无 X-Tenant-Id 且无认证 token 租户时，租户中间件会写入该默认租户。
TENANT_DEFAULT_ID=default

# 是否允许请求头 X-Tenant-Id 覆盖默认租户。未接入认证前本地联调通常保持 true，生产环境应结合认证策略收紧。
TENANT_ALLOW_HEADER_OVERRIDE=true

# JWT 签发方，必须与访问令牌校验配置保持一致。
AUTH_JWT_ISSUER=taipus-api

# JWT 受众，必须与访问令牌校验配置保持一致。
AUTH_JWT_AUDIENCE=api

# JWT 密钥 ID，用于后续密钥轮换。当前服务只接受与该值一致的 kid。
AUTH_JWT_KID=local-dev

# RS256 私钥 PEM。示例使用转义换行；生产环境必须替换为独立生成并妥善托管的私钥。
# 可用命令生成开发密钥：openssl genrsa -out jwt-private.pem 2048 && openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
AUTH_JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n请替换为本地或部署环境的 RS256 私钥\n-----END PRIVATE KEY-----"

# RS256 公钥 PEM。必须与 AUTH_JWT_PRIVATE_KEY_PEM 配对。
AUTH_JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n请替换为与私钥配对的 RS256 公钥\n-----END PUBLIC KEY-----"

# 访问令牌有效期，单位秒。默认 15 分钟。
AUTH_ACCESS_TOKEN_TTL_SECONDS=900

# 刷新令牌有效期，单位秒。默认 30 天。
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000

# 刷新令牌 pepper，用于数据库落库前哈希。生产环境必须使用高强度随机字符串，并通过密钥管理系统或部署平台注入。
AUTH_REFRESH_TOKEN_PEPPER=replace-with-a-long-random-refresh-token-pepper

# 首次启动管理员账号。四个 AUTH_BOOTSTRAP_ADMIN_* 必须同时配置；账号已存在时不会覆盖密码。
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe_123456
AUTH_BOOTSTRAP_ADMIN_DISPLAY_NAME=系统管理员
AUTH_BOOTSTRAP_ADMIN_TENANT_ID=default
