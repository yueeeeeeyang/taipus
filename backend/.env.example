# 当前配置样例用于本地开发和部署配置对照，实际敏感配置应写入 backend/.env 或部署平台环境变量。

# 应用运行环境，可按部署环境设置为 local、test、staging 或 production。
APP_ENV=local

# HTTP 服务监听地址，容器内通常使用 0.0.0.0，本机限定访问可改为 127.0.0.1。
SERVER_HOST=0.0.0.0

# HTTP 服务监听端口，必须是合法的 0-65535 端口号。
SERVER_PORT=8080

# 数据库类型，当前支持 mysql、postgres、postgresql、pg，其中默认运行目标为 mysql。
DATABASE_TYPE=mysql

# 数据库连接串，MySQL 使用 mysql://，PostgreSQL 使用 postgres:// 或 postgresql://。
DATABASE_URL=mysql://root:root@127.0.0.1:3306/taipus

# 数据库连接池最大连接数，必须大于 0。
DATABASE_MAX_CONNECTIONS=20

# 数据库连接池最小连接数，不得大于 DATABASE_MAX_CONNECTIONS。
DATABASE_MIN_CONNECTIONS=1

# 获取数据库连接的超时时间，单位为秒。
DATABASE_CONNECT_TIMEOUT_SECONDS=5

# 是否在服务启动时自动执行 Refinery migration，支持 true/false/1/0/yes/no/on/off。
DATABASE_RUN_MIGRATIONS=true

# tracing 日志过滤级别，常用值为 error、warn、info、debug、trace。
RUST_LOG=info

# 多语言默认 locale，必须和 backend/locales 中的资源文件 locale 保持一致。
I18N_DEFAULT_LOCALE=zh-CN

# 多语言支持 locale 列表，逗号分隔；配置会在启动时规范化并校验资源文件是否存在。
I18N_SUPPORTED_LOCALES=zh-CN,en-US

# 默认 IANA time zone，业务代码不得写死默认展示时区。
I18N_DEFAULT_TIME_ZONE=Asia/Shanghai

# 支持的 IANA time zone 列表，逗号分隔；未配置时只启用默认时区。
I18N_SUPPORTED_TIME_ZONES=Asia/Shanghai,UTC,America/New_York

# 系统多语言资源版本，用于前端和移动端缓存失效。
I18N_SYSTEM_RESOURCE_VERSION=202604280001
